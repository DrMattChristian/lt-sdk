ST_VENDOR_SDK_PATH      := thirdparty/vendor-sdk/stmicro/stm32-F4-discovery
ST_VENDOR_SDK_ROOT      := $(LT_PLATFORM_ROOT)/$(ST_VENDOR_SDK_PATH)
ST_VENDOR_SDK_LD_SCRIPT := $(ST_VENDOR_SDK_ROOT)/STM32F407VGTx_FLASH.ld

######
# step 0 - specify the LT_LTKERNEL_ARCHITECTURE for this platform
LT_LTKERNEL_ARCHITECTURE := LT_LTKERNEL_ARCHITECTURE_ARM_CORTEX_V7M

######
# step 1 - set LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER to yes or no
LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER := no

######
# step 2 - set one of either LT_GCC_TOOLCHAIN_PATH or LT_GCC_TOOLCHAIN_TGZ.
         #   If LT_GCC_TOOLCHAIN_PATH is set, it is taken as the path containing toolchain binaries.
         #   If LT_GCC_TOOLCHAIN_TGZ is set, it identifies the toolchain tarball which is placed
         #   into a subdir of LT_VENDOR_TOOLCHAINS_DIR, where the master makefile sets LT_GCC_TOOLCHAIN_PATH from.
         #   ISSUE: redo this - perhaps make an LT_TOOLCHAINS_ROOT with vendor-toolchain-tarball/ and vendor-toolchain/
LT_VENDOR_TOOLCHAIN_TGZ ?= st-arm-none-eabi-gcc-7.3.1-20180622-x86_64.tgz
LT_GCC_TOOLCHAIN_PREFIX := arm-none-eabi

######
# step 3 - add or subtract default toolchain flags/switches.  ----> No -D switches or -I switches allowed <------
#LT_DISABLE_STATS        := yes

# CPU
ST_CPU_FLAGS      := -mcpu=cortex-m4 -mthumb
# NOTE: The STM32F4 Discovery CPU supports hardware floating point acceleration
#       However, we are using the soft ABI here for emulator support.
ST_CPU_FLAGS      += -mfloat-abi=soft
#ST_CPU_FLAGS      += -mfpu=fpv4-sp-d16 -mfloat-abi=hard

LT_CFLAGS_GENERIC += $(ST_CPU_FLAGS)
LT_CFLAGS_GENERIC += -ffreestanding -fno-jump-tables
LT_CFLAGS_GENERIC += -Wno-write-strings -Wno-maybe-uninitialized

LT_CFLAGS_DEBUG        += -gdwarf-2

LT_LDFLAGS_MASTERING   := $(ST_CPU_FLAGS)
LT_LDFLAGS_MASTERING   += -T$(ST_VENDOR_SDK_LD_SCRIPT)

######
# step 4 - add optional LT_PLATFORM_PROJECT_ONLY_DEFS
#          LT_PLATFORM_PROJECT_ONLY_DEFS are used only for platform projects (LT_PLATFORM_LTCOREBSP_PROJECT, LT_PLATFORM_DRIVER_PROJECTS and LT_PLATFORM_MASTERING_PROJECTS)
#          They are NOT added to OS projects or PRODUCT projects.
LT_PLATFORM_PROJECT_ONLY_DEFS += -DUSE_HAL_DRIVER
LT_PLATFORM_PROJECT_ONLY_DEFS += -DSTM32F407xx
LT_PLATFORM_PROJECT_ONLY_DEFS += -DST_F4_DISCOVERY

######
# step 5 - specify LT_PLATFORM_LTCOREBSP_PROJECT, LT_PLATFORM_DRIVER_PROJECTS, and optional LT_PLATFORM_MASTERING_PROJECTS
LT_PLATFORM_LTCOREBSP_PROJECT  := STLTCoreBSP

LT_PLATFORM_DRIVER_PROJECTS    :=

LT_PLATFORM_MASTERING_PROJECTS := STMasterFirmwareImage


