#
################################################################################

######
# step 0 - specify the LT_LTKERNEL_ARCHITECTURE for this platform
LT_LTKERNEL_ARCHITECTURE := LT_LTKERNEL_ARCHITECTURE_BSP_DEFINED_HOST_OS

######
# step 1 - set LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER to yes or no
LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER  := yes
LT_NULLIFY_ALL_NON_SERVER_LTLOGS        := no
LT_NULLIFY_ALL_LT_ASSERTS               := no

######
# step 2 - set one of either LT_GCC_TOOLCHAIN_PATH or LT_GCC_TOOLCHAIN_TGZ.
         #   If LT_GCC_TOOLCHAIN_PATH is set, it is taken as the path containing toolchain binaries.
         #   If LT_GCC_TOOLCHAIN_TGZ is set, it identifies the toolchain tarball which is placed
         #   into a subdir of LT_VENDOR_TOOLCHAINS_DIR, where the master makefile sets LT_GCC_TOOLCHAIN_PATH from.
         #   ISSUE: redo this - perhaps make an LT_TOOLCHAINS_ROOT with vendor-toolchain-tarball/ and vendor-toolchain/
LT_GCC_TOOLCHAIN_PATH   := /usr/bin
LT_GCC_TOOLCHAIN_PREFIX :=

######
# step 3 - add or subtract default toolchain flags/switches.  ----> No -D switches or -I switches allowed <------
LT_LD_FRONTEND		= $(LT_CC)

##
# MACOS specific xcode flags
#
LT_XCODE_MACOS_SDKROOT := /Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk

#LT_XCODE_MACOS_CFLAGS   := -isysroot $(LT_XCODE_MACOS_SDKROOT)
LT_XCODE_MACOS_CFLAGS   :=
LT_XCODE_MACOS_CXXFLAGS := $(LT_XCODE_MACOS_CFLAGS)
LT_XCODE_MACOS_LDFLAGS  := $(LT_XCODE_MACOS_CFLAGS)

LT_XCODE_MACOS_LDFLAGS    += -dead_strip -fobjc-arc -fobjc-link-runtime

LT_CFLAGS_GENERIC	:= $(patsubst -fstack-usage,,$(LT_CFLAGS_GENERIC))
LT_CFLAGS_GENERIC       += $(LT_XCODE_MACOS_CFLAGS) -Wno-unused-private-field -Wnarrowing
LT_CFLAGS_GENERIC       += -DLT_TEXT_RAM_CRITICAL_THRESHOLD=0 -DLT_RODATA_RAM_CRITICAL_THRESHOLD=0
LT_CFLAGS_GENERIC       += -fno-builtin
LT_CFLAGS_DEBUG         := $(patsubst -Og,,$(LT_CFLAGS_DEBUG))
# LT_CFLAGS_RELEASE     +=
LT_CXXFLAGS_GENERIC	:= $(patsubst -fstack-usage,,$(LT_CXXFLAGS_GENERIC))
LT_CXXFLAGS_GENERIC     += $(LT_xCODE_MACOS_CXXFLAGS) -Wno-unused-private-field -Wnarrowing
LT_CXXFLAGS_DEBUG       := $(patsubst -Og,,$(LT_CFLAGS_DEBUG))
ifneq (,$(LT_SANITIZE))
LT_CFLAGS_GENERIC   += -fsanitize=$(LT_SANITIZE) -fno-omit-frame-pointer
LT_CXXFLAGS_GENERIC += -fsanitize=$(LT_SANITIZE) -fno-omit-frame-pointer
endif
# LT_CXXFLAGS_RELEASE   +=
LT_LDFLAGS_SHAREDLIB    += $(LT_XCODE_MACOS_LDFLAGS)
LT_LDFLAGS_EXECUTABLE   += $(LT_XCODE_MACOS_LDFLAGS)
ifneq (,$(LT_SANITIZE))
ifeq (address,$(LT_SANITIZE))
LT_LDFLAGS_EXECUTABLE   += -lasan
LT_LDFLAGS_SHAREDLIB    += -lasan
endif
ifeq (undefined,$(LT_SANITIZE))
LT_LDFLAGS_EXECUTABLE   += -lubsan
LT_LDFLAGS_SHAREDLIB    += -lubsan
endif
LT_LDFLAGS_EXECUTABLE   += -fsanitize=$(LT_SANITIZE)
LT_LDFLAGS_SHAREDLIB    += -fsanitize=$(LT_SANITIZE)
endif

# LT_ARFLAGS_STATICLIB  +=
LT_STRIPFLAGS_STRIPALL  := $(patsubst -s,-S,$(LT_STRIPFLAGS_STRIPALL))

LT_DISABLE_STATS        := yes

######
# step 4 - add optional LT_PLATFORM_PROJECT_ONLY_DEFS
#          LT_PLATFORM_PROJECT_ONLY_DEFS are used only for platform projects (LT_PLATFORM_LTCOREBSP_PROJECT, LT_PLATFORM_DRIVER_PROJECTS and LT_PLATFORM_MASTERING_PROJECTS)
#          They are NOT added to OS projects or PRODUCT projects.
LT_PLATFORM_PROJECT_ONLY_DEFS   :=

######
# step 5 - specify LT_PLATFORM_LTCOREBSP_PROJECT, LT_PLATFORM_DRIVER_PROJECTS, and optional LT_PLATFORM_MASTERING_PROJECTS
LT_PLATFORM_LTCOREBSP_PROJECT		:= MacOSLTCoreBSP

LT_PLATFORM_DRIVER_PROJECTS		:= MacOSDriverFlash MacOSDriverWatchdog MacOSDriverWiFi

LT_PLATFORM_MASTERING_PROJECTS 	:= libltrun ltrun

