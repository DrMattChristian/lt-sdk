################################################################################
#
# File: platforms/apple/build/platform/ios/Makefile.config
#
# This platform Makefile.config file defines the LT makefile variables necessary for
# building LT on the macos platform.
#
#
# This Source Code Form is subject to the terms of the Mozilla Public License, v. 2.0.
# If a copy of the MPL was not distributed with this file, you can obtain one at
# https://mozilla.org/MPL/2.0/.
#
# Copyright 2021, Roku, Inc.  All rights reserved.
#
################################################################################

######
# step 0 - specify the LT_LTKERNEL_ARCHITECTURE for this platform
LT_LTKERNEL_ARCHITECTURE := LT_LTKERNEL_ARCHITECTURE_BSP_DEFINED_HOST_OS

######
# step 1 - set LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER to yes or no
LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER  := yes
LT_NULLIFY_ALL_NON_SERVER_LTLOGS        := no
LT_NULLIFY_ALL_LT_ASSERTS               := no

######
# step 2 - set one of either LT_GCC_TOOLCHAIN_PATH or LT_GCC_TOOLCHAIN_TGZ.
         #   If LT_GCC_TOOLCHAIN_PATH is set, it is taken as the path containing toolchain binaries.
         #   If LT_GCC_TOOLCHAIN_TGZ is set, it identifies the toolchain tarball which is placed
         #   into a subdir of LT_VENDOR_TOOLCHAINS_DIR, where the master makefile sets LT_GCC_TOOLCHAIN_PATH from.
         #   ISSUE: redo this - perhaps make an LT_TOOLCHAINS_ROOT with vendor-toolchain-tarball/ and vendor-toolchain/
LT_GCC_TOOLCHAIN_PATH   := /usr/bin
LT_GCC_TOOLCHAIN_PREFIX :=

######
# step 3 - add or subtract default toolchain flags/switches.  ----> No -D switches or -I switches allowed <------
#

# First change the ld frontend to gcc; linux requires g++, gcc is better and it works on apple
# use = instead of := so it gets evaluated properly
LT_LD_FRONTEND = $(LT_CC)

##
# IOS specific xcode flags
#
LT_XCODE_IOS_SDKROOT := /Applications/Xcode.app/Contents/Developer/Platforms/iPhoneOS.platform/Developer/SDKs/iPhoneOS15.0.sdk

LT_XCODE_IOS_CFLAGS   := -target arm64-apple-ios14.7 -isysroot $(LT_XCODE_IOS_SDKROOT)
LT_XCODE_IOS_CXXFLAGS := $(LT_XCODE_IOS_CFLAGS)
LT_XCODE_IOS_LDFLAGS  := $(LT_XCODE_IOS_CFLAGS)

# LT_XCODE_IOS_CFLAGS   += -fembed-bitcode
# LT_XCODE_IOS_CFLAGS   += -fmessage-length\=0 -fno-common -fstrict-aliasing -g

LT_XCODE_IOS_LDFLAGS     += -dead_strip -fobjc-arc -fobjc-link-runtime
#LT_XCODE_IOS_LDFLAGS    += -framework CoreData -framework UIKit

##
# CFLAGS
#
LT_CFLAGS_GENERIC	:= $(patsubst -ffunction-sections,,$(LT_CFLAGS_GENERIC))
LT_CFLAGS_GENERIC	:= $(patsubst -fdata-sections,,$(LT_CFLAGS_GENERIC))
LT_CFLAGS_GENERIC	:= $(patsubst -fstack-usage,,$(LT_CFLAGS_GENERIC))
LT_CFLAGS_GENERIC   += $(LT_XCODE_IOS_CFLAGS) -Wno-unused-private-field -Wnarrowing
LT_CFLAGS_GENERIC   += -DLT_TEXT_RAM_CRITICAL_THRESHOLD=0 -DLT_RODATA_RAM_CRITICAL_THRESHOLD=0
LT_CFLAGS_DEBUG     := $(patsubst -Og,,$(LT_CFLAGS_DEBUG))
#LT_CFLAGS_RELEASE  +=

##
# CXX FLAGS
#
LT_CXXFLAGS_GENERIC	:= $(patsubst -fstack-usage,,$(LT_CXXFLAGS_GENERIC))
LT_CXXFLAGS_GENERIC     += $(LT_XCODE_IOS_CXXFLAGS) -Wno-unused-private-field -Wnarrowing
LT_CXXFLAGS_DEBUG       := $(patsubst -Og,,$(LT_CFLAGS_DEBUG))
# LT_CXXFLAGS_RELEASE   +=

##
# LD FLAGS
#
LT_LDFLAGS_SHAREDLIB    += $(LT_XCODE_IOS_LDFLAGS)
LT_LDFLAGS_EXECUTABLE   += $(LT_XCODE_IOS_LDFLAGS)

##
# AR and STRIP FLAGS
#
LT_STRIPFLAGS_STRIPALL  := $(patsubst -s,-S,$(LT_STRIPFLAGS_STRIPALL))
# LT_ARFLAGS_STATICLIB  +=

##
# SANITIZER OPTIONS
#
ifneq (,$(LT_SANITIZE))
    LT_CFLAGS_GENERIC			+= -fsanitize=$(LT_SANITIZE) -fno-omit-frame-pointer
    LT_CXXFLAGS_GENERIC 		+= -fsanitize=$(LT_SANITIZE) -fno-omit-frame-pointer
    LT_LDFLAGS_SHAREDLIB    		+= -fsanitize=$(LT_SANITIZE)
    LT_LDFLAGS_EXECUTABLE   		+= -fsanitize=$(LT_SANITIZE)
    ifeq (address,$(LT_SANITIZE))
        LT_LDFLAGS_SHAREDLIB    	+= -lasan
        LT_LDFLAGS_EXECUTABLE   	+= -lasan
    endif
    ifeq (undefined,$(LT_SANITIZE))
        LT_LDFLAGS_SHAREDLIB    	+= -lubsan
        LT_LDFLAGS_EXECUTABLE   	+= -lubsan
    endif
endif

##
# STATS DISABLEMENT
#
LT_DISABLE_STATS        := yes

######
# step 4 - add optional LT_PLATFORM_PROJECT_ONLY_DEFS
#          LT_PLATFORM_PROJECT_ONLY_DEFS are used only for platform projects (LT_PLATFORM_LTCOREBSP_PROJECT, LT_PLATFORM_DRIVER_PROJECTS and LT_PLATFORM_MASTERING_PROJECTS)
#          They are NOT added to OS projects or PRODUCT projects.
LT_PLATFORM_PROJECT_ONLY_DEFS   :=

######
# step 5 - specify LT_PLATFORM_LTCOREBSP_PROJECT, LT_PLATFORM_DRIVER_PROJECTS, and optional LT_PLATFORM_MASTERING_PROJECTS
LT_PLATFORM_LTCOREBSP_PROJECT		:= iOSLTCoreBSP

LT_PLATFORM_DRIVER_PROJECTS		:= iOSDriverFlash iOSDriverWiFi

LT_PLATFORM_MASTERING_PROJECTS          := liblthost ios_code_sign_ltlibraries

# mega trim for iOS - don't build libraries that aren't needed

LT_OS_PROJECTS := $(patsubst LTDeviceLED,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDevicePCMAudioOutput,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDevicePins,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDevicePotentiometer,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDevicePushButton,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDeviceRotaryEncoder,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDeviceSlider,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDeviceThermometer,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDeviceWatchdog,,$(LT_OS_PROJECTS))
#LT_OS_PROJECTS := $(patsubst LTDeviceWiFi,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDeviceI2C,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDeviceKeyInput,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTDeviceSPI,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTShellWiFi,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTSystemLoader,,$(LT_OS_PROJECTS))

