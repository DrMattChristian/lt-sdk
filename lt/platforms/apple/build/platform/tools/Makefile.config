  LT_LTKERNEL_ARCHITECTURE 				  := LT_LTKERNEL_ARCHITECTURE_BSP_DEFINED_HOST_OS
  LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER  := no
  LT_NULLIFY_ALL_NON_SERVER_LTLOGS        := no
  LT_NULLIFY_ALL_LT_ASSERTS               := no

  LT_GCC_TOOLCHAIN_PATH   				  ?= /usr/bin
  LT_GCC_TOOLCHAIN_PREFIX 				  :=
  LT_CFLAGS_GENERIC       				  += -nostdlib -fno-builtin -DLTCOREBSP_TOOLS_BUILD -Wno-void-pointer-to-enum-cast -U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=0

  LT_DISABLE_STATS                        := yes

  LT_PLATFORM_LTCOREBSP_PROJECT			  := LTCoreBSP_AppleTools

