# 1. include the base lt of product Makefile.config file
#
include $(LT_OS_ROOT)/build/product/$(LT_PRODUCT)/Makefile.config

# 2. exclude the libraries we don't care about
#
LT_OS_PROJECTS := $(patsubst IoTBrightScriptController,,$(LT_OS_PROJECTS))
LT_OS_PROJECTS := $(patsubst LTSystemBrightScript,,$(LT_OS_PROJECTS))

