################################################################################
#
# File: platforms/linux/build/platform/x86Cloud/Makefile.config
#
# This platform Makefile.config file defines the LT makefile variables necessary for
# building LT on the linux[x86] platform, with a cloud-friendly environment that
# requires no additional system privileges.
#
#
# This Source Code Form is subject to the terms of the Mozilla Public License, v. 2.0.
# If a copy of the MPL was not distributed with this file, you can obtain one at
# https://mozilla.org/MPL/2.0/.
#
# Copyright 2022, Roku, Inc.  All rights reserved.
#
################################################################################

  LT_LTKERNEL_ARCHITECTURE                := LT_LTKERNEL_ARCHITECTURE_BSP_DEFINED_HOST_OS
  LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER  := yes
  LT_NULLIFY_ALL_NON_SERVER_LTLOGS        := no
  LT_NULLIFY_ALL_LT_ASSERTS               := no

  LT_GCC_TOOLCHAIN_PATH                   ?= /usr/bin
  LT_GCC_TOOLCHAIN_PREFIX                 :=
  LT_PLATFORM_LTCOREBSP_PROJECT           := LinuxLTCoreBSPCloud
  LT_PLATFORM_MASTERING_PROJECTS 	      := libltrun ltrun

  ifneq (,$(LT_SANITIZE))
    ifeq (address,$(LT_SANITIZE))
      LT_LDFLAGS_EXECUTABLE   += -lasan
      LT_LDFLAGS_SHAREDLIB    += -lasan
    endif
    ifeq (undefined,$(LT_SANITIZE))
      LT_LDFLAGS_EXECUTABLE   += -lubsan
      LT_LDFLAGS_SHAREDLIB    += -lubsan
    endif
    LT_LDFLAGS_EXECUTABLE   += -fsanitize=$(LT_SANITIZE)
    LT_LDFLAGS_SHAREDLIB    += -fsanitize=$(LT_SANITIZE)
  endif

