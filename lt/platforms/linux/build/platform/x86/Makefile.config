################################################################################

  LT_LTKERNEL_ARCHITECTURE                := LT_LTKERNEL_ARCHITECTURE_BSP_DEFINED_HOST_OS
  LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER  := yes
  LT_NULLIFY_ALL_NON_SERVER_LTLOGS        := no
  LT_NULLIFY_ALL_LT_ASSERTS               := no

  LT_GCC_TOOLCHAIN_PATH                   ?= /usr/bin
  LT_GCC_TOOLCHAIN_PREFIX                 :=

  LT_PLATFORM_LTCOREBSP_PROJECT           := LinuxLTCoreBSP
  LT_PLATFORM_MASTERING_PROJECTS 	      := libltrun ltrun

ifeq (unittest, $(LT_PRODUCT))
  ifneq (1, $(LT_DISABLE_CRASHING_GCOV_LIBRARY))
    LT_CFLAGS_GENERIC                       += --coverage
    LT_LDFLAGS_SHAREDLIB                    += --coverage -lgcov
    LT_LDFLAGS_EXECUTABLE                   += --coverage -lgcov
  endif
endif

ifneq (,$(LT_SANITIZE))
  ifeq (address,$(LT_SANITIZE))
    LT_LDFLAGS_EXECUTABLE                 += -lasan
    LT_LDFLAGS_SHAREDLIB                  += -lasan
  endif
  ifeq (undefined,$(LT_SANITIZE))
    LT_LDFLAGS_EXECUTABLE                 += -lubsan
    LT_LDFLAGS_SHAREDLIB                  += -lubsan
  endif
  LT_LDFLAGS_EXECUTABLE                   += -fsanitize=$(LT_SANITIZE)
  LT_LDFLAGS_SHAREDLIB                    += -fsanitize=$(LT_SANITIZE)
endif

