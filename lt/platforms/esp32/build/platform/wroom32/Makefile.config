# 1. set platform specific build parameters for enacted build
#            a.  ltk architecture ident, has runtime loader status, bsp and mastering project ident,
#            b.  platform only vendor sdk defs, e.g. include paths for platform projects
#            c.  optional update to global CFLAGS with cross-compiler specific CFLAGS to use globally
SOC_PLATFORM_NAME                       := esp32
LT_LTKERNEL_ARCHITECTURE                := LT_LTKERNEL_ARCHITECTURE_XTENSA
LT_PLATFORM_HAS_RUNTIME_DYNAMIC_LOADER  := no
LT_NULLIFY_ALL_NON_SERVER_LTLOGS        := no
LT_NULLIFY_ALL_LT_ASSERTS               := no

LT_PLATFORM_LTCOREBSP_PROJECT           := Esp32_LTCoreBSP
LT_PLATFORM_MASTERING_PROJECTS          := Esp32_MasterFirmwareImage
LT_PLATFORM_PROJECT_ONLY_DEFS           += -I$(LT_PLATFORM_PUBLIC_INCLUDE_DIR)/$(SOC_PLATFORM_NAME)

LT_CFLAGS_DEBUG                         += -gdwarf-3
LT_CFLAGS_GENERIC                       += -ffreestanding -fno-jump-tables -fdiagnostics-color=auto -mlongcalls -Wno-undef
LT_CFLAGS_GENERIC                       += -DLT_TEXT_RAM_CRITICAL_THRESHOLD=0 -DLT_RODATA_RAM_CRITICAL_THRESHOLD=0
#                                       TODO: add named SRAM segmengs to linker definitions file and change these THRESHOLDS accordingly

# 2. setup toolchain variables
LT_GCC_TOOLCHAIN_PREFIX := xtensa-esp32-elf
ifeq ($(LT_TOOLCHAIN_HOST_OS_NAME), Darwin)
    # MAC
    ifeq ($(LT_TOOLCHAIN_HOST_ARCHITECTURE), arm64)
        LT_VENDOR_TOOLCHAIN_TGZ ?= xtensa-esp32-elf-gcc11_2_0-esp-2022r1-macos-arm64.txz
    else
        LT_VENDOR_TOOLCHAIN_TGZ ?= xtensa-esp32-elf-gcc11_2_0-esp-2022r1-macos.txz
    endif
else
    # NOT MAC
    ifeq ($(LT_TOOLCHAIN_HOST_ARCHITECTURE), x86_64)
        LT_VENDOR_TOOLCHAIN_TGZ ?= xtensa-esp32-elf-gcc11_2_0-esp-2022r1-linux-amd64.tar.xz
        LT_GCC_TOOLCHAIN_NAME := xtensa-esp32-elf
    endif
    ifeq ($(LT_TOOLCHAIN_HOST_ARCHITECTURE), aarch64)
        LT_VENDOR_TOOLCHAIN_TGZ ?= xtensa-esp32-elf-gcc11_2_0-esp-2022r1-linux-arm64.tgz
    endif
    LT_VENDOR_TOOLCHAIN_TGZ ?= xtensa-esp32-elf-gcc11_2_0-esp-2022r1-linux-i686.tgz
endif

